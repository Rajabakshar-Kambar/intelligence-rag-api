# ─────────────────────────────────────────────────────────────────────────────
# CloudSpring Intelligence RAG API — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# In production, set these as ECS task definition environment variables,
# AWS Parameter Store references, or Secrets Manager injections.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ──────────────────────────────────────────────────────────────────────
# For production: leave blank and rely on the ECS task role / EC2 instance profile.
# For local development: provide IAM user credentials with minimum permissions:
#   bedrock:InvokeModel on amazon.titan-embed-text-v2:0
#   bedrock:InvokeModel on anthropic.claude-3-haiku-20240307-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

AWS_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
AWS_CHAT_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Bedrock SDK timeouts (seconds)
AWS_CALL_ATTEMPT_TIMEOUT=10
AWS_CALL_TIMEOUT=30

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=company-documents

# Set a strong random value for production Qdrant instances.
# Leave blank for local dev (Qdrant runs without auth by default).
QDRANT_API_KEY=

# Set to true and configure TLS in production.
QDRANT_USE_TLS=false

# ── API Security ──────────────────────────────────────────────────────────────
# Leave blank to disable API key authentication (local dev only).
# In production, generate with: openssl rand -hex 32
API_KEY=

# ── RAG Tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.60
RAG_MAX_CONTEXT_CHUNKS=4
RAG_MAX_CONTEXT_TOKENS=6000
RAG_MIN_ANSWERABLE_SCORE=0.60
RAG_FALLBACK_TOP_K=2

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev